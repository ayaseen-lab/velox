PORT=3001
DAILY_LIMIT=490

# Account 1 — Primary sender
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Ahmad Yaseen
SMTP_ACCOUNT_1_USER=your-email@gmail.com
SMTP_ACCOUNT_1_PASS=your-app-password
SMTP_ACCOUNT_1_DAILY_LIMIT=490
SMTP_ACCOUNT_1_DELAY_MS=5000

# Account 2 — Protected (lower limit, slower sends)
SMTP_ACCOUNT_2_USER=your-second-email@gmail.com
SMTP_ACCOUNT_2_PASS=your-app-password
SMTP_ACCOUNT_2_FROM_NAME=Ahmad Yaseen
SMTP_ACCOUNT_2_DAILY_LIMIT=490
SMTP_ACCOUNT_2_DELAY_MS=8000

SEND_DELAY_MS=5000
TEST_EMAIL=test@example.com
MAX_RETRIES=3
